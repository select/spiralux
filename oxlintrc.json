{
  "$schema": "https://raw.githubusercontent.com/nicolo-ribaudo/oxc-project.github.io/compiled-schema/configuration.schema.json",
  "plugins": ["typescript", "import"],
  "categories": {
    "correctness": "error",
    "suspicious": "warn",
    "pedantic": "off",
    "style": "off",
    "nursery": "off"
  },
  "rules": {
    "no-unused-vars": "warn",
    "no-console": "warn",
    "no-debugger": "error",
    "eqeqeq": "error",
    "no-var": "error",
    "prefer-const": "warn",
    "prefer-template": "warn",
    "typescript/no-explicit-any": "warn",
    "typescript/no-non-null-assertion": "off",
    "import/no-duplicates": "warn",
    "import/consistent-type-specifier-style": "warn",
    "import/no-unassigned-import": "off"
  },
  "ignorePatterns": ["dist/**", "node_modules/**", "*.config.*"]
}
